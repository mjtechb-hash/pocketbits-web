<script>
    // ✅ সরাসরি ডাউনলোড লিংক (GitHub raw URL)
    const APK_URL = "https://github.com/mjtechb-hash/PocketBitsy/raw/8663c0d2db64cc23241030c3017abc4a23bc60b6/PocketBits.apk";

    function downloadAPK() {
        const a = document.createElement('a');
        a.href = APK_URL;
        a.download = "PocketBits.apk";
        document.body.appendChild(a);
        a.click();
        document.body.removeChild(a);
        alert("📱 PocketBits APK ডাউনলোড শুরু হয়েছে!\n\nইন্সটল করার পর রেজিস্ট্রেশন করে আয় শুরু করুন।");
    }

    document.getElementById('downloadBtn').addEventListener('click', downloadAPK);
    document.getElementById('downloadBtn2').addEventListener('click', downloadAPK);

    // Smooth scroll
    document.querySelectorAll('a[href^="#"]').forEach(a => {
        a.addEventListener('click', e => {
            e.preventDefault();
            const t = document.querySelector(a.getAttribute('href'));
            if (t) t.scrollIntoView({ behavior: 'smooth' });
        });
    });

    // Scroll reveal
    const allReveal = document.querySelectorAll('.reveal, .reveal-left, .stagger-children');
    const io = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
            if (entry.isIntersecting) {
                entry.target.classList.add('active');
                io.unobserve(entry.target);
            }
        });
    }, { threshold: 0.12 });

    allReveal.forEach(el => io.observe(el));

    // Loader hide
    window.addEventListener('load', () => {
        setTimeout(() => {
            document.getElementById('loader').classList.add('hidden');
        }, 1000);
    });

    // Live counter animation
    let liveVal = 124800;
    setInterval(() => {
        liveVal += Math.floor(Math.random() * 50) + 10;
        const el = document.getElementById('countNum');
        if (el) el.textContent = liveVal.toLocaleString('en-IN');
    }, 3000);
</script>
