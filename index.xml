<!DOCTYPE html>
<html lang="bn">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=yes, viewport-fit=cover">
    <title>PocketBits — Earn Real Money | bKash & Nagad Withdrawal</title>
    <meta name="description" content="PocketBits এ প্রতিদিন টাস্ক সম্পন্ন করে কয়েন আয় করুন। সরাসরি bKash ও Nagad এ টাকা তুলুন।">
    <meta name="theme-color" content="#0052FF">
    
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    
    <style>
        :root {
            --blue: #0052FF;
            --blue-dark: #003ACC;
            --blue-light: #E8F0FF;
            --gold: #FFB800;
            --gold-light: #FFF4CC;
            --bg: #FFFFFF;
            --surface: #F4F6FB;
            --surface2: #EEF1F8;
            --text: #0A0F1E;
            --text-muted: #6B7280;
            --border: #E5E9F2;
            --shadow-blue: rgba(0,82,255,0.18);
            --shadow-card: 0 2px 0 #D8DCE8;
        }

        * { margin: 0; padding: 0; box-sizing: border-box; }

        body {
            font-family: 'Plus Jakarta Sans', sans-serif;
            background: var(--bg);
            color: var(--text);
            overflow-x: hidden;
        }

        html { scroll-behavior: smooth; }

        /* ── LOADER ── */
        .loader {
            position: fixed;
            inset: 0;
            background: #fff;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            z-index: 9999;
            transition: opacity 0.6s ease, visibility 0.6s ease;
        }

        .loader.hidden { opacity: 0; visibility: hidden; }

        .loader-logo {
            width: 64px;
            height: 64px;
            background: var(--blue);
            border-radius: 20px;
            display: flex;
            align-items: center;
            justify-content: center;
            margin-bottom: 20px;
            animation: loaderPulse 1.2s ease-in-out infinite;
        }

        .loader-logo i { color: white; font-size: 28px; }

        @keyframes loaderPulse {
            0%, 100% { transform: scale(1); box-shadow: 0 0 0 0 rgba(0,82,255,0.4); }
            50% { transform: scale(1.08); box-shadow: 0 0 0 16px rgba(0,82,255,0); }
        }

        .loader-bar {
            width: 120px;
            height: 3px;
            background: var(--surface2);
            border-radius: 3px;
            overflow: hidden;
        }

        .loader-bar-fill {
            height: 100%;
            background: var(--blue);
            border-radius: 3px;
            animation: loaderFill 1s ease forwards;
        }

        @keyframes loaderFill { from { width: 0; } to { width: 100%; } }

        /* ── NAV ── */
        .nav {
            position: sticky;
            top: 0;
            z-index: 100;
            background: rgba(255,255,255,0.96);
            backdrop-filter: blur(20px);
            border-bottom: 1px solid var(--border);
            padding: 12px 20px;
        }

        .nav-inner {
            max-width: 500px;
            margin: 0 auto;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .logo {
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .logo-icon {
            width: 38px;
            height: 38px;
            background: linear-gradient(135deg, #0052FF, #003ACC);
            border-radius: 11px;
            display: flex;
            align-items: center;
            justify-content: center;
            box-shadow: 0 4px 12px var(--shadow-blue);
        }

        .logo-icon i { color: white; font-size: 17px; }

        .logo-text {
            font-size: 20px;
            font-weight: 900;
            color: var(--text);
            letter-spacing: -0.5px;
        }

        .logo-text span { color: var(--gold); }

        .nav-links { display: flex; gap: 20px; }

        .nav-links a {
            text-decoration: none;
            color: var(--text-muted);
            font-size: 13px;
            font-weight: 600;
            transition: color 0.2s;
        }

        .nav-links a:hover { color: var(--blue); }

        /* ── CONTAINER ── */
        .container { max-width: 500px; margin: 0 auto; padding: 0 20px; }

        /* ── HERO ── */
        .hero {
            padding: 44px 0 20px;
            text-align: center;
        }

        .hero-badge {
            display: inline-flex;
            align-items: center;
            gap: 7px;
            background: var(--blue-light);
            color: var(--blue);
            padding: 7px 16px;
            border-radius: 50px;
            font-size: 12px;
            font-weight: 700;
            margin-bottom: 22px;
            border: 1px solid rgba(0,82,255,0.15);
        }

        .hero-badge i { font-size: 11px; }

        .hero h1 {
            font-size: 34px;
            font-weight: 900;
            line-height: 1.2;
            letter-spacing: -1px;
            margin-bottom: 16px;
        }

        .hero h1 .highlight {
            background: linear-gradient(135deg, #FFB800, #FF8C00);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        .hero-desc {
            font-size: 14px;
            color: var(--text-muted);
            line-height: 1.65;
            margin-bottom: 28px;
            padding: 0 8px;
        }

        /* ── CTA BUTTON ── */
        .btn-primary {
            background: linear-gradient(135deg, #0052FF 0%, #003ACC 100%);
            border: none;
            color: white;
            font-family: 'Plus Jakarta Sans', sans-serif;
            font-weight: 800;
            font-size: 16px;
            padding: 17px 24px;
            border-radius: 60px;
            cursor: pointer;
            width: 100%;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 10px;
            box-shadow: 0 8px 0 #002699, 0 12px 24px var(--shadow-blue);
            transition: all 0.12s ease;
            position: relative;
            overflow: hidden;
        }

        .btn-primary::after {
            content: '';
            position: absolute;
            top: 0; left: -100%;
            width: 60%;
            height: 100%;
            background: linear-gradient(90deg, transparent, rgba(255,255,255,0.15), transparent);
            animation: shimmer 2.4s ease infinite;
        }

        @keyframes shimmer {
            0% { left: -100%; }
            50%, 100% { left: 150%; }
        }

        .btn-primary:active {
            transform: translateY(5px);
            box-shadow: 0 3px 0 #002699, 0 5px 12px var(--shadow-blue);
        }

        .btn-primary i { font-size: 16px; }

        /* ── STATS ── */
        .stats {
            display: flex;
            justify-content: center;
            gap: 10px;
            margin-top: 28px;
        }

        .stat-item {
            flex: 1;
            text-align: center;
            background: var(--surface);
            border-radius: 18px;
            padding: 14px 8px;
            border: 1px solid var(--border);
            cursor: pointer;
            transition: all 0.2s ease;
        }

        .stat-item:active { transform: scale(0.95); background: var(--blue-light); }

        .stat-icon {
            width: 32px;
            height: 32px;
            background: var(--blue-light);
            border-radius: 10px;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 8px;
        }

        .stat-icon i { color: var(--blue); font-size: 14px; }

        .stat-number {
            font-size: 20px;
            font-weight: 900;
            color: var(--blue);
            letter-spacing: -0.5px;
        }

        .stat-label { font-size: 10px; color: var(--text-muted); font-weight: 600; margin-top: 2px; }

        /* ── HERO CARD ── */
        .hero-card {
            margin-top: 28px;
            background: linear-gradient(135deg, #0A0F1E 0%, #1A2448 100%);
            border-radius: 28px;
            padding: 28px 22px;
            position: relative;
            overflow: hidden;
        }

        .hero-card::before {
            content: '';
            position: absolute;
            top: -60px; right: -60px;
            width: 200px; height: 200px;
            background: radial-gradient(circle, rgba(0,82,255,0.35) 0%, transparent 70%);
            border-radius: 50%;
        }

        .hero-card::after {
            content: '';
            position: absolute;
            bottom: -40px; left: -40px;
            width: 160px; height: 160px;
            background: radial-gradient(circle, rgba(255,184,0,0.2) 0%, transparent 70%);
            border-radius: 50%;
        }

        .hero-card-content { position: relative; z-index: 1; }

        .users-row {
            display: flex;
            align-items: center;
            gap: 12px;
            margin-bottom: 16px;
        }

        .avatars {
            display: flex;
        }

        .avatar {
            width: 34px;
            height: 34px;
            border-radius: 50%;
            border: 2px solid #1A2448;
            background: var(--blue);
            display: flex;
            align-items: center;
            justify-content: center;
            margin-left: -10px;
        }

        .avatar:first-child { margin-left: 0; }
        .avatar i { color: white; font-size: 14px; }
        .avatar.a2 { background: #7C3AED; }
        .avatar.a3 { background: #059669; }
        .avatar.a4 { background: var(--gold); }

        .users-text { color: white; font-size: 13px; font-weight: 600; }
        .users-text span { color: var(--gold); }

        .earning-row {
            display: flex;
            align-items: center;
            justify-content: space-between;
        }

        .earning-text { color: rgba(255,255,255,0.6); font-size: 12px; }
        .earning-amount {
            font-size: 28px;
            font-weight: 900;
            color: white;
            letter-spacing: -1px;
        }

        .earning-amount span { color: var(--gold); }

        .earning-badge {
            display: inline-flex;
            align-items: center;
            gap: 5px;
            background: rgba(0,255,120,0.15);
            color: #00E87A;
            padding: 5px 10px;
            border-radius: 20px;
            font-size: 11px;
            font-weight: 700;
            border: 1px solid rgba(0,255,120,0.25);
        }

        .earning-badge i { font-size: 10px; }

        /* ── SECTIONS ── */
        .section { padding: 44px 0 0; }

        .section-eyebrow {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            color: var(--blue);
            font-size: 11px;
            font-weight: 700;
            letter-spacing: 1.5px;
            text-transform: uppercase;
            margin-bottom: 10px;
        }

        .section-eyebrow i { font-size: 10px; }

        .section-title {
            font-size: 26px;
            font-weight: 900;
            letter-spacing: -0.7px;
            margin-bottom: 8px;
        }

        .section-sub {
            color: var(--text-muted);
            font-size: 13px;
            line-height: 1.6;
            margin-bottom: 28px;
        }

        /* ── FEATURES GRID ── */
        .features-grid {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 14px;
        }

        .feature-card {
            background: var(--surface);
            border-radius: 22px;
            padding: 22px 16px;
            cursor: pointer;
            border: 1px solid var(--border);
            box-shadow: var(--shadow-card);
            transition: all 0.12s ease;
        }

        .feature-card:active {
            transform: translateY(2px);
            box-shadow: none;
        }

        .feature-icon {
            width: 48px;
            height: 48px;
            border-radius: 16px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 22px;
            margin-bottom: 14px;
        }

        .feature-icon.blue { background: var(--blue-light); color: var(--blue); }
        .feature-icon.gold { background: var(--gold-light); color: #CC8800; }
        .feature-icon.green { background: #DCFCE7; color: #16A34A; }
        .feature-icon.purple { background: #F3E8FF; color: #7C3AED; }

        .feature-card h3 {
            font-size: 15px;
            font-weight: 800;
            margin-bottom: 5px;
            letter-spacing: -0.3px;
        }

        .feature-card p { color: var(--text-muted); font-size: 12px; line-height: 1.5; }

        /* ── STEPS ── */
        .steps { display: flex; flex-direction: column; gap: 14px; }

        .step {
            display: flex;
            align-items: center;
            gap: 16px;
            background: var(--surface);
            padding: 18px 16px;
            border-radius: 22px;
            cursor: pointer;
            border: 1px solid var(--border);
            box-shadow: var(--shadow-card);
            transition: all 0.12s ease;
        }

        .step:active {
            transform: translateY(2px);
            box-shadow: none;
        }

        .step-num {
            width: 46px;
            height: 46px;
            background: linear-gradient(135deg, var(--blue), var(--blue-dark));
            border-radius: 16px;
            display: flex;
            align-items: center;
            justify-content: center;
            flex-shrink: 0;
            box-shadow: 0 4px 10px var(--shadow-blue);
        }

        .step-num i { color: white; font-size: 18px; }

        .step-body h3 {
            font-size: 15px;
            font-weight: 800;
            margin-bottom: 3px;
            letter-spacing: -0.3px;
        }

        .step-body p { font-size: 12px; color: var(--text-muted); }

        /* ── CONNECTOR LINE ── */
        .steps .step:not(:last-child) { position: relative; }

        /* ── LEVELS ── */
        .level-grid {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 14px;
        }

        .level-card {
            background: var(--surface);
            border-radius: 22px;
            padding: 22px 16px;
            cursor: pointer;
            border: 1px solid var(--border);
            box-shadow: var(--shadow-card);
            transition: all 0.12s ease;
            position: relative;
            overflow: hidden;
        }

        .level-card::before {
            content: '';
            position: absolute;
            top: 0; left: 0; right: 0;
            height: 3px;
        }

        .level-card.bronze::before { background: linear-gradient(90deg, #CD7F32, #E8A66C); }
        .level-card.silver::before { background: linear-gradient(90deg, #9EA8B8, #C8D0DC); }
        .level-card.gold::before { background: linear-gradient(90deg, #FFB800, #FFD700); }
        .level-card.diamond::before { background: linear-gradient(90deg, #0052FF, #7C3AED); }

        .level-card:active {
            transform: translateY(2px);
            box-shadow: none;
        }

        .level-badge {
            width: 44px;
            height: 44px;
            border-radius: 14px;
            display: flex;
            align-items: center;
            justify-content: center;
            margin-bottom: 12px;
        }

        .level-badge i { font-size: 20px; }

        .level-card.bronze .level-badge { background: #FDF2E9; color: #CD7F32; }
        .level-card.silver .level-badge { background: #F4F5F7; color: #9EA8B8; }
        .level-card.gold .level-badge { background: var(--gold-light); color: #CC8800; }
        .level-card.diamond .level-badge { background: var(--blue-light); color: var(--blue); }

        .level-name {
            font-size: 16px;
            font-weight: 900;
            letter-spacing: -0.3px;
            margin-bottom: 3px;
        }

        .level-range { font-size: 10px; color: var(--text-muted); margin-bottom: 8px; }

        .level-mult {
            display: inline-flex;
            align-items: center;
            gap: 4px;
            font-size: 12px;
            font-weight: 800;
            color: var(--gold);
            background: var(--gold-light);
            padding: 3px 9px;
            border-radius: 20px;
        }

        .level-mult i { font-size: 10px; color: #CC8800; }

        /* ── DOWNLOAD CTA ── */
        .download-cta {
            background: linear-gradient(135deg, #0A0F1E 0%, #1A2448 100%);
            border-radius: 28px;
            padding: 40px 24px;
            margin: 44px 0;
            text-align: center;
            position: relative;
            overflow: hidden;
        }

        .download-cta::before {
            content: '';
            position: absolute;
            top: -80px; right: -80px;
            width: 240px; height: 240px;
            background: radial-gradient(circle, rgba(0,82,255,0.3) 0%, transparent 70%);
        }

        .download-cta::after {
            content: '';
            position: absolute;
            bottom: -60px; left: -60px;
            width: 200px; height: 200px;
            background: radial-gradient(circle, rgba(255,184,0,0.15) 0%, transparent 70%);
        }

        .download-cta-inner { position: relative; z-index: 1; }

        .cta-icon {
            width: 64px;
            height: 64px;
            background: rgba(255,255,255,0.1);
            border-radius: 22px;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 20px;
            border: 1px solid rgba(255,255,255,0.15);
        }

        .cta-icon i { color: white; font-size: 28px; }

        .download-cta h2 {
            color: white;
            font-size: 24px;
            font-weight: 900;
            letter-spacing: -0.6px;
            margin-bottom: 10px;
        }

        .download-cta p {
            color: rgba(255,255,255,0.6);
            font-size: 13px;
            margin-bottom: 24px;
            line-height: 1.6;
        }

        .btn-white {
            background: white;
            color: var(--text);
            font-family: 'Plus Jakarta Sans', sans-serif;
            font-weight: 800;
            font-size: 16px;
            padding: 17px 24px;
            border-radius: 60px;
            cursor: pointer;
            width: 100%;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 10px;
            border: none;
            box-shadow: 0 8px 0 rgba(0,0,0,0.25);
            transition: all 0.12s ease;
        }

        .btn-white i { color: var(--blue); font-size: 16px; }
        .btn-white:active { transform: translateY(5px); box-shadow: 0 3px 0 rgba(0,0,0,0.25); }

        .trust-row {
            display: flex;
            justify-content: center;
            gap: 16px;
            margin-top: 18px;
        }

        .trust-item {
            display: flex;
            align-items: center;
            gap: 5px;
            color: rgba(255,255,255,0.5);
            font-size: 11px;
            font-weight: 600;
        }

        .trust-item i { color: #00E87A; font-size: 11px; }

        /* ── FOOTER ── */
        .footer {
            background: var(--surface);
            border-top: 1px solid var(--border);
            padding: 32px 20px;
            text-align: center;
        }

        .footer-logo {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
            margin-bottom: 12px;
        }

        .footer-logo-icon {
            width: 32px;
            height: 32px;
            background: var(--blue);
            border-radius: 9px;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .footer-logo-icon i { color: white; font-size: 14px; }

        .footer-text {
            font-size: 16px;
            font-weight: 900;
            color: var(--text);
        }

        .footer-text span { color: var(--gold); }

        .footer p {
            color: var(--text-muted);
            font-size: 12px;
            margin-top: 8px;
            line-height: 1.6;
        }

        .footer-links {
            display: flex;
            justify-content: center;
            gap: 20px;
            margin-top: 16px;
        }

        .footer-links a {
            color: var(--text-muted);
            font-size: 12px;
            font-weight: 600;
            text-decoration: none;
        }

        /* ── SCROLL REVEAL ── */
        .reveal {
            opacity: 0;
            transform: translateY(40px);
            transition: opacity 0.7s cubic-bezier(0.2,0.9,0.4,1), transform 0.7s cubic-bezier(0.2,0.9,0.4,1);
        }

        .reveal.active {
            opacity: 1;
            transform: translateY(0);
        }

        .reveal-left {
            opacity: 0;
            transform: translateX(-30px);
            transition: opacity 0.6s cubic-bezier(0.2,0.9,0.4,1), transform 0.6s cubic-bezier(0.2,0.9,0.4,1);
        }

        .reveal-left.active {
            opacity: 1;
            transform: translateX(0);
        }

        /* Staggered children */
        .stagger-children > * {
            opacity: 0;
            transform: translateY(24px);
            transition: opacity 0.5s ease, transform 0.5s ease;
        }

        .stagger-children.active > *:nth-child(1) { opacity: 1; transform: translateY(0); transition-delay: 0ms; }
        .stagger-children.active > *:nth-child(2) { opacity: 1; transform: translateY(0); transition-delay: 80ms; }
        .stagger-children.active > *:nth-child(3) { opacity: 1; transform: translateY(0); transition-delay: 160ms; }
        .stagger-children.active > *:nth-child(4) { opacity: 1; transform: translateY(0); transition-delay: 240ms; }

        /* Hero entrance */
        .hero-badge, .hero h1, .hero-desc, .btn-primary, .stats, .hero-card {
            opacity: 0;
            animation: heroEntrance 0.7s cubic-bezier(0.2,0.9,0.4,1) forwards;
        }

        .hero-badge  { animation-delay: 0.1s; }
        .hero h1     { animation-delay: 0.2s; }
        .hero-desc   { animation-delay: 0.3s; }
        .btn-primary { animation-delay: 0.4s; }
        .stats       { animation-delay: 0.5s; }
        .hero-card   { animation-delay: 0.6s; }

        @keyframes heroEntrance {
            from { opacity: 0; transform: translateY(28px); }
            to   { opacity: 1; transform: translateY(0); }
        }

        /* Floating dots background */
        .dot-bg {
            position: absolute;
            border-radius: 50%;
            background: rgba(0,82,255,0.06);
            animation: float 6s ease-in-out infinite;
        }

        @keyframes float {
            0%, 100% { transform: translateY(0); }
            50% { transform: translateY(-14px); }
        }

        /* Counter animation */
        .count-up { display: inline-block; }

        /* Pulse ring on CTA */
        .pulse-ring {
            position: relative;
            display: inline-block;
        }

        .pulse-ring::before {
            content: '';
            position: absolute;
            inset: -6px;
            border-radius: 70px;
            border: 2px solid rgba(0,82,255,0.3);
            animation: pulseRing 2s ease-out infinite;
        }

        @keyframes pulseRing {
            0% { transform: scale(1); opacity: 1; }
            100% { transform: scale(1.08); opacity: 0; }
        }

        /* Ticker */
        .ticker {
            background: var(--blue);
            padding: 8px 0;
            overflow: hidden;
            white-space: nowrap;
        }

        .ticker-inner {
            display: inline-block;
            animation: tickerScroll 18s linear infinite;
        }

        .ticker-inner span {
            color: white;
            font-size: 12px;
            font-weight: 700;
